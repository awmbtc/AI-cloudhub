HTTP_ADDR=:8080
# JWT secret: >=16 chars; production must not use dev-change-me
JWT_SECRET=dev-change-me
PRESIGN_TTL_MIN=15

# Strict mode: weak JWT / missing master key become hard errors (production)
# AI_CLOUDHUB_STRICT=1

# Open registration (default true). Set false after bootstrap admin exists.
# AI_CLOUDHUB_ALLOW_REGISTER=0

# Session token lifetime hours (default 24)
# AI_CLOUDHUB_TOKEN_TTL_HOURS=24

# Request body size cap bytes (default 1048576)
# AI_CLOUDHUB_MAX_BODY_BYTES=1048576

# Optional metrics scrape token (Bearer or ?token=)
# AI_CLOUDHUB_METRICS_TOKEN=

# Login/register rate limit per IP and failure lockout
# AI_CLOUDHUB_AUTH_RATE_PER_MIN=20
# AI_CLOUDHUB_AUTH_FAIL_MAX=8
# AI_CLOUDHUB_AUTH_FAIL_WINDOW_MIN=15
# Trust X-Forwarded-For / X-Real-IP for client IP (only behind trusted reverse proxy)
# AI_CLOUDHUB_TRUST_PROXY=1

# Store: sqlite path | memory | postgres DSN
# AI_CLOUDHUB_DB=./data/ai-cloudhub.db
# AI_CLOUDHUB_DB=memory
# AI_CLOUDHUB_DB=postgres://aihub:aihub@localhost:5432/aihub?sslmode=disable

# Shared rate limit (multi-instance). Empty = in-process token bucket.
# AI_CLOUDHUB_REDIS=redis://localhost:6379/0
# AI_CLOUDHUB_REDIS_LIMIT=120
# AI_CLOUDHUB_REDIS_WINDOW_SEC=60

# Envelope encryption for provider secrets (production required)
# AI_CLOUDHUB_MASTER_KEY=   # openssl rand -base64 32

# Public URL for manifests
# AI_CLOUDHUB_PUBLIC_URL=https://api.example.com

# Optional MinIO / AWS STS
# AI_CLOUDHUB_MINIO_STS=1
# AI_CLOUDHUB_AWS_STS=1
# AI_CLOUDHUB_AWS_STS_ROLE_ARN=arn:aws:iam::...:role/...

# Legacy platform S3 workspace (not main product path)
# ENABLE_PLATFORM_S3=1
S3_ENDPOINT=127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1
BUCKET_PREFIX=ws-
